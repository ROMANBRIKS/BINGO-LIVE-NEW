rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "rogershep101@gmail.com" ||
        request.auth.uid == "YDnNAkdp5sYRs8YNN8K22576UO33" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isRecent(ts) {
      return ts is timestamp && 
             ts > request.time - duration.value(300, 's') &&
             ts < request.time + duration.value(300, 's');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
      
      match /following/{followingId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow write: if isAuthenticated();
      }
    }

    match /easter_eggs/{eggId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.hostUid == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.hostUid == request.auth.uid || isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasAny(['currentBeans', 'viewerCount', 'pkScore', 'pkOpponentScore', 'seats']));
      allow delete: if isAuthenticated() && (resource.data.hostUid == request.auth.uid || isAdmin());

      match /messages/{msgId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid;
      }

      match /seatRequests/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }

      match /private_calls/{callId} {
        allow read: if isAuthenticated() && (request.auth.uid == roomId || request.auth.uid == resource.data.viewerUid || isAdmin());
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && (request.auth.uid == roomId || request.auth.uid == resource.data.viewerUid || isAdmin());
      }

      match /signals/{signalId} {
        allow read: if isAuthenticated() && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from || isAdmin());
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.from;
        allow delete: if isAuthenticated() && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from || isAdmin());
      }

      match /polls/{pollId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (request.auth.uid == roomId || isAdmin());

        match /votes/{userId} {
          allow read: if isAuthenticated();
          allow write: if isOwner(userId);
        }
      }

      match /chaos_events/{eventId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (request.auth.uid == roomId || isAdmin());
      }

      match /egg_drops/{dropId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && (request.auth.uid == roomId || isAdmin());
        allow update: if isAuthenticated() && (request.auth.uid == roomId || isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && resource.data.status == 'active'));
        allow delete: if isAuthenticated() && (request.auth.uid == roomId || isAdmin());
      }

      match /features/{featureId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (featureId == 'treasureChest' || request.auth.uid == roomId || isAdmin());
      }
    }

    match /predictions/{predictionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.hostUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.hostUid == request.auth.uid || 
        isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalYes', 'totalNo'])
      );
    }

    match /bets/{betId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /bank/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /features/{featureId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /gifts/{giftId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid || isAdmin());
      allow create: if isAuthenticated();
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.followerUid == request.auth.uid;
    }

    match /{path=**}/private_calls/{callId} {
      allow read: if isAdmin();
    }
  }
}
