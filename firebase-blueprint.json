{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the Bingo Live platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "diamonds": { "type": "number", "description": "Current diamond balance" },
        "beans": { "type": "number", "description": "Current bean balance (convertible to cash)" },
        "role": { "type": "string", "enum": ["user", "host", "agency", "admin", "moderator"], "description": "User's role" },
        "nobleTitle": { "type": "string", "enum": ["None", "Baron", "Duke", "Grand Duke", "Archduke", "King", "Emperor", "Global God"], "description": "VIP noble title" },
        "agencyId": { "type": "string", "description": "ID of the agency the user belongs to (if host)" },
        "familyId": { "type": "string", "description": "ID of the host family" },
        "totalDiamondsSpent": { "type": "number", "description": "Total diamonds spent for leaderboard" },
        "totalBeansEarned": { "type": "number", "description": "Total beans earned for host salary" },
        "adBeans": { "type": "number", "description": "Current Ad Bean balance (from watching sponsors)" },
        "totalAdBeansEarned": { "type": "number", "description": "Total cumulative Ad Beans earned" },
        "referralCode": { "type": "string", "description": "User's unique referral code" },
        "invitedBy": { "type": "string", "description": "UID of the user who invited this user" },
        "isBanned": { "type": "boolean", "description": "Whether user is banned from the service" },
        "isShadowBanned": { "type": "boolean", "description": "Whether user is shadow-banned" },
        "suspendedUntil": { "type": "string", "description": "ISO format timestamp of suspension ending" },
        "suspensionReason": { "type": "string", "description": "Brief explanation tag for suspension" },
        "customFallbackSalaryRate": { "type": "number", "description": "Manual override rate for streamer fallback base salary bonus" },
        "appealText": { "type": "string", "description": "Appeal reasons specified by streamer" },
        "appealStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"], "description": "Streamer appeal state" }
      },
      "required": ["uid", "displayName", "diamonds", "beans", "role"]
    },
    "Agency": {
      "title": "Agency",
      "description": "Represents an agency managing hosts.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Agency unique ID" },
        "name": { "type": "string", "description": "Agency name" },
        "ownerUid": { "type": "string", "description": "UID of the agency owner" },
        "tier": { "type": "number", "description": "Agency tier (1-5)" },
        "commissionRate": { "type": "number", "description": "Agency commission percentage" },
        "rebateRate": { "type": "number", "description": "Agency rebate percentage" },
        "totalHosts": { "type": "number", "description": "Number of hosts in the agency" }
      },
      "required": ["id", "name", "ownerUid", "tier"]
    },
    "Room": {
      "title": "Room",
      "description": "Represents a live streaming room.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Room unique ID (usually host UID)" },
        "hostUid": { "type": "string", "description": "UID of the host" },
        "title": { "type": "string", "description": "Room title" },
        "status": { "type": "string", "enum": ["live", "ended"], "description": "Current stream status" },
        "type": { "type": "string", "enum": ["video", "audio"], "description": "Stream type" },
        "currentBeans": { "type": "number", "description": "Beans earned in the current session" },
        "viewerCount": { "type": "number", "description": "Current number of viewers" },
        "guests": { "type": "array", "items": { "type": "string" }, "description": "List of guest UIDs" },
        "isPrivate": { "type": "boolean", "description": "Whether the session is encrypted/private" },
        "pkStatus": { "type": "string", "enum": ["idle", "searching", "battling"], "description": "Current PK battle status" },
        "pkOpponentUid": { "type": "string", "description": "UID of the PK opponent" },
        "pkOpponentRoomId": { "type": "string", "description": "Room ID of the PK opponent" },
        "pkScore": { "type": "number", "description": "Host's current PK score" },
        "pkOpponentScore": { "type": "number", "description": "Opponent's current PK score" },
        "pkEndTime": { "type": "string", "format": "date-time", "description": "When the PK battle ends" }
      },
      "required": ["id", "hostUid", "status", "type"]
    },
    "Gift": {
      "title": "Gift",
      "description": "Represents a gift item.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Gift ID" },
        "name": { "type": "string", "description": "Gift name" },
        "cost": { "type": "number", "description": "Cost in diamonds" },
        "image": { "type": "string", "description": "URL or emoji for the gift" },
        "animationType": { "type": "string", "description": "Type of animation to play" },
        "category": { "type": "string", "description": "Gift category (e.g., Popular, Noble)" },
        "isFlash": { "type": "boolean", "description": "Whether it's a limited-time gift" },
        "expiresAt": { "type": "string", "format": "date-time", "description": "Expiration time for flash gifts" }
      },
      "required": ["id", "name", "cost", "image", "animationType"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a diamond/bean transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Transaction ID" },
        "fromUid": { "type": "string", "description": "Sender UID" },
        "toUid": { "type": "string", "description": "Receiver UID" },
        "amount": { "type": "number", "description": "Amount of diamonds/beans" },
        "type": { "type": "string", "enum": ["purchase", "gift", "salary", "rebate", "prediction_bet", "prediction_payout"], "description": "Transaction type" },
        "referenceId": { "type": "string", "description": "ID of the related entity (e.g., giftId, predictionId)" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Transaction time" }
      },
      "required": ["id", "fromUid", "toUid", "amount", "type", "timestamp"]
    },
    "Prediction": {
      "title": "Prediction",
      "description": "Represents a prediction event (poll/bet) in a stream.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "hostUid": { "type": "string" },
        "question": { "type": "string" },
        "sideYes": { "type": "string" },
        "sideNo": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed", "settled", "cancelled"] },
        "winningSide": { "type": "string", "enum": ["yes", "no", null] },
        "totalYes": { "type": "number" },
        "totalNo": { "type": "number" },
        "model": { "type": "number", "enum": [1, 2] },
        "targetMultiplier": { "type": "number" },
        "actualMultiplier": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "roomId", "hostUid", "question", "status", "model"]
    },
    "Bet": {
      "title": "Bet",
      "description": "Represents a user's bet on a prediction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "predictionId": { "type": "string" },
        "side": { "type": "string", "enum": ["yes", "no"] },
        "amount": { "type": "number" },
        "settled": { "type": "boolean" },
        "payout": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "predictionId", "side", "amount", "timestamp"]
    },
    "Bank": {
      "title": "Bank",
      "description": "Represents the house reserve for Model 2 payouts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "balance": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "balance", "lastUpdated"]
    },
    "Message": {
      "title": "Message",
      "description": "Represents a chat message or event in a room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string", "description": "Message content (required for 'chat' type)" },
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "level": { "type": "number" },
        "nobleTitle": { "type": "string", "description": "User's noble title (accolade)" },
        "type": { "type": "string", "enum": ["chat", "join", "like", "system", "follow", "welcome", "follow-prompt", "guest-live-prompt", "like-prompt"] },
        "hostName": { "type": "string", "description": "The name of the host (for welcome messages)" },
        "hostPhoto": { "type": "string", "description": "The photo URL of the host (for welcome messages)" },
        "hostLevel": { "type": "number", "description": "The level of the host (for welcome messages)" },
        "isGift": { "type": "boolean" },
        "isNew": { "type": "boolean", "description": "Whether the user is new to the room" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "photoURL", "timestamp"]
    },
    "Follow": {
      "title": "Follow",
      "description": "Represents a follow relationship between users.",
      "type": "object",
      "properties": {
        "followerUid": { "type": "string" },
        "followingUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["followerUid", "followingUid", "timestamp"]
    },
    "EasterEgg": {
      "title": "EasterEgg",
      "description": "Definition of an Easter Egg drop.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "rewardType": { "type": "string", "enum": ["beans", "diamonds"] },
        "rewardValue": { "type": "number" },
        "rarity": { "type": "string", "enum": ["common", "rare", "legendary"] },
        "isEnabled": { "type": "boolean", "description": "Whether this egg is active for drops" }
      },
      "required": ["id", "name", "image", "rewardType", "rewardValue"]
    },
    "EggDrop": {
      "title": "EggDrop",
      "description": "An active Easter Egg drop in a room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eggId": { "type": "string" },
        "eggImage": { "type": "string" },
        "rewardType": { "type": "string" },
        "rewardValue": { "type": "number" },
        "x": { "type": "number", "description": "Horizontal position %" },
        "y": { "type": "number", "description": "Vertical position %" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "collected", "expired"] }
      },
      "required": ["id", "eggId", "x", "y", "status"]
    },
    "MigrationRequest": {
      "title": "MigrationRequest",
      "description": "A request to migrate status from another platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "platform": { "type": "string" },
        "proofUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "matchedRank": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "platform", "proofUrl", "status"]
    },
    "Family": {
      "title": "Family",
      "description": "Represents a host family/clan.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "badge": { "type": "string" },
        "ownerUid": { "type": "string" },
        "description": { "type": "string" },
        "memberCount": { "type": "number" },
        "memberLimit": { "type": "number" },
        "combatPoints": { "type": "number", "description": "Persistent XP from gifts" },
        "monthlyPoints": { "type": "number", "description": "Points earned this month" },
        "monthlyTarget": { "type": "number", "description": "Target points for this month" },
        "level": { "type": "number" },
        "tier": { "type": "string" }
      },
      "required": ["id", "name", "ownerUid", "combatPoints", "level", "tier"]
    },
    "AgencyMember": {
      "title": "AgencyMember",
      "description": "Represents a streamer host affiliated with an agency.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "agencyId": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "totalEarnings": { "type": "number" },
        "commissionPaid": { "type": "number" },
        "tier": { "type": "string", "enum": ["Junior", "Senior", "Elite", "Master"] }
      },
      "required": ["agencyId", "tier"]
    },
    "FanClubMember": {
      "title": "FanClubMember",
      "description": "Represents a fan of a host.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "hostUid": { "type": "string" },
        "level": { "type": "number" },
        "intimacyPoints": { "type": "number" },
        "lastCheckIn": { "type": "number" },
        "isSuperFan": { "type": "boolean" }
      },
      "required": ["uid", "hostUid", "level", "intimacyPoints"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Represents a real cash withdrawal requested by a host.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique withdrawal record ID" },
        "userId": { "type": "string", "description": "UID of the host who withdrew" },
        "userName": { "type": "string", "description": "Display name of the user" },
        "userEmail": { "type": "string", "description": "Email address of the user" },
        "userPhoto": { "type": "string", "description": "Photo URL of the user" },
        "beansAmount": { "type": "number", "description": "Number of conversion beans deducted" },
        "usdAmount": { "type": "number", "description": "Equivalent USD value payout" },
        "method": { "type": "string", "description": "Withdrawal route (e.g. PayPal)" },
        "status": { "type": "string", "enum": ["pending", "completed", "rejected"], "description": "Withdrawal approval state" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Request creation timestamp" }
      },
      "required": ["id", "userId", "userName", "beansAmount", "usdAmount", "status", "timestamp"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Represents a diamond purchase made by a user using real money.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction record ID" },
        "userId": { "type": "string", "description": "UID of the buyer" },
        "userName": { "type": "string", "description": "Display name of the buyer" },
        "diamondsBought": { "type": "number", "description": "Diamonds purchased" },
        "priceUSD": { "type": "number", "description": "Cash cost paid in USD" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Purchase transaction time" }
      },
      "required": ["id", "userId", "userName", "diamondsBought", "priceUSD", "timestamp"]
    },
    "AdImpression": {
      "title": "AdImpression",
      "description": "An audited advertisement impression registered by a spectator watching a streamer.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Impression entry ID" },
        "hostUid": { "type": "string", "description": "Streamer UID" },
        "viewerUid": { "type": "string", "description": "Spectator UID" },
        "viewerName": { "type": "string", "description": "Spectator Display Name" },
        "campaignId": { "type": "string", "description": "Sponsor Campaign ID" },
        "campaignBrand": { "type": "string", "description": "Brand Category name" },
        "country": { "type": "string", "description": "Spectator Region Country code" },
        "countryName": { "type": "string", "description": "Spectator Region full name" },
        "ip": { "type": "string", "description": "Spectator IP address" },
        "isVpn": { "type": "boolean", "description": "Whether proxy bypass signals were flagged" },
        "cpmValue": { "type": "number", "description": "Ad CPM rate paid" },
        "adBeansEarned": { "type": "number", "description": "Earned Ad Beans share fraction" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Record timestamp" }
      },
      "required": ["id", "hostUid", "viewerUid", "campaignId", "country", "timestamp"]
    },
    "SuspensionReport": {
      "title": "SuspensionReport",
      "description": "Represents a livestream suspension and safety audit infraction log.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique suspension entry ID" },
        "userId": { "type": "string", "description": "UID of the suspended user" },
        "userName": { "type": "string", "description": "Display name of the user" },
        "userPhoto": { "type": "string", "description": "Photo URL of the user" },
        "reason": { "type": "string", "description": "Suspension infraction reason explanation" },
        "screenshotUrl": { "type": "string", "description": "Silent sensitive image evidence capture in base64/dataURL representation" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Infraction log timestamp" },
        "appealText": { "type": "string", "description": "Reason text provided by streamer to appeal" },
        "appealStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"], "description": "Resolution status of user appeal" },
        "resolvedBy": { "type": "string", "description": "UID of staff member resolving this appeal" }
      },
      "required": ["id", "userId", "reason", "timestamp", "appealStatus"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and balances."
    },
    "/families/{familyId}": {
      "schema": "Family",
      "description": "Family details and rankings."
    },
    "/agencies/{agencyId}": {
      "schema": "Agency",
      "description": "Agency details and tiers."
    },
    "/agency_members/{streamerUid}": {
      "schema": "AgencyMember",
      "description": "Affiliated streamers under an agency representation."
    },
    "/fan_club_members/{memberKey}": {
      "schema": "FanClubMember",
      "description": "Fan club level and intimacy metrics."
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Live stream room states."
    },
    "/gifts/{giftId}": {
      "schema": "Gift",
      "description": "Available gift items."
    },
    "/easter_eggs/{eggId}": {
      "schema": "EasterEgg",
      "description": "Definitions of platform Easter Eggs."
    },
    "/rooms/{roomId}/egg_drops/{dropId}": {
      "schema": "EggDrop",
      "description": "Active drops in a room."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "History of all financial movements."
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages within a room."
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "User follow relationships."
    },
    "/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Prediction events."
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "User bets on predictions."
    },
    "/bank/{bankId}": {
      "schema": "Bank",
      "description": "House reserve for Model 2."
    },
    "/migration_requests/{requestId}": {
      "schema": "MigrationRequest",
      "description": "Status migration oversight."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "Withdrawal",
      "description": "Real cash out records."
    },
    "/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "Store recharge deposit history."
    },
    "/ad_impressions/{impressionId}": {
      "schema": "AdImpression",
      "description": "Geotargeted advertiser impression logs and security signal audits."
    },
    "/suspensions/{reportId}": {
      "schema": "SuspensionReport",
      "description": "User livestream suspensions and policy violation logs."
    }
  }
}
